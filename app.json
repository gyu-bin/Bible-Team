{
  "expo": {
    "name": "Bible Crew",
    "slug": "bible-crew",
    "version": "1.0.0",
    "scheme": "bible-crew",
    "orientation": "portrait",
    "icon": "./assets/logo/bible_logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/bible_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biblecrew.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/bible_logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.biblecrew.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "bible-crew",
              "host": "group",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "읽기 인증용으로 사진을 선택할 수 있어요.",
          "cameraPermission": "읽기 인증용으로 카메라를 사용해요."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ca1e225d-b890-4bbe-950b-4b6daf644a28"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ca1e225d-b890-4bbe-950b-4b6daf644a28"
    }
  }
}
